{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "api/**/*.ts",
    "lib/**/*.ts",
    "services/**/*.ts",
    "cache/**/*.ts",
    "middleware/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts"
  ]
}
