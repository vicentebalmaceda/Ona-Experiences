# ============ Frontend (Vite) ============

# Leave empty to call the API on the same origin (/api/v1/*), which is the
# default now that the BFF is deployed with the web app on Vercel.
# Set a full URL only if the API lives on another origin (e.g. https://api.example.com).
VITE_API_URL=

# Backend target for the Vite dev proxy.
# - http://localhost:3003 → BFF dev server (npm run dev:bff-local) — recommended
# - http://localhost:3002 → legacy Express API (npm run dev:api) — rollback only
VITE_API_PROXY_TARGET=http://localhost:3003

# ============ BFF (Vercel Serverless Functions) ============
# Server-side only. Vite never exposes non-VITE_ variables to the browser.
# In production these are set as Vercel project environment variables.

# BSale API (required)
BSALE_ACCESS_TOKEN=
BSALE_API_BASE_URL=https://api.bsale.io/v1

# Logging: debug | info | warn | error (defaults: debug in dev, info in prod)
LOG_LEVEL=
# Comma-separated list of allowed browser origins (localhost is always allowed in dev)
CORS_ORIGIN=http://localhost:5173

# BSale product type names (must match types created in BSale admin)
BSALE_LODGE_PRODUCT_TYPE_NAME=LODGE
BSALE_GUIDE_PRODUCT_TYPE_NAME=GUIDE

# BSale sales / cotización (resolve from sandbox: document_types, offices, price_lists)
BSALE_OFFICE_ID=1
BSALE_QUOTE_DOCUMENT_TYPE_ID=1
BSALE_PRICE_LIST_ID=1

# Shared secret for /api/webhooks/bsale (optional; leave empty to disable the check)
BSALE_WEBHOOK_SECRET=

# Vercel KV / Upstash Redis for the distributed cache (optional; falls back to
# per-instance memory cache when unset). Provided automatically by Vercel KV.
KV_REST_API_URL=
KV_REST_API_TOKEN=
