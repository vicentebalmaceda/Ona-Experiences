# BSale API (required)
BSALE_ACCESS_TOKEN=your_sandbox_token_here
BSALE_API_BASE_URL=https://api.bsale.io/v1

# Server
PORT=3001
NODE_ENV=development
# debug | info | warn | error (defaults to debug in development, info in production)
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# BSale product type names (must match types created in BSale admin)
BSALE_LODGE_PRODUCT_TYPE_NAME=LODGE
BSALE_GUIDE_PRODUCT_TYPE_NAME=GUIDE
